procedure TForm1.btn_IgualClick(Sender: TObject);
  var n1, n2: double;
begin
  n1:= strToFloat (edt_Visor1.Text);
  n2:= strToFloat (edt_Visor2.Text);

  //Fazendo a soma

  if (lb_Operador.Caption = '+') Then
  begin
     lb_resposta.caption := (floattostr(n1 + n2));
  end;

  //Fazendo a subtração

  if (lb_Operador.Caption = '-') then
  begin
    lb_resposta.caption := (floattostr(n1 - n2));
  end;

  //Fazendo a multiplicação

  if (lb_Operador.caption = 'X') then
  begin
    lb_resposta.caption := (floattostr(n1 * n2));
  end;

  //Fazendo a divisão

    if (lb_Operador.caption = '/') then
  begin
    lb_resposta.caption := (floattostr(n1 / n2));
  end;



  end;

